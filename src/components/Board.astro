---
// src/components/Board.astro — a shared "r/place-ish" canvas: one bounded image,
// everyone draws/writes on it, atomic compare-and-swap save, ~4s polling.
// Works on localStorage immediately; goes shared once Supabase keys are filled in below.
const PALETTE = ['#1d1c18', '#5b5650', '#ffffff', '#e5484d', '#f76b15', '#ffb224',
	'#46a758', '#12a594', '#2a4bd0', '#6a35c9', '#e93d82', '#8a5a2b'];
---

<div class="board" id="board" aria-hidden="true">
	<div class="board-bar">
		<span class="board-title">the board</span>
		<div class="board-group">
			<button class="bt active" data-tool="brush" id="toolBrush" title="brush" aria-label="brush">
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19l7-7 3 3-7 7-3-3z"></path><path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"></path><path d="M2 2l7.586 7.586"></path><circle cx="11" cy="11" r="2"></circle></svg>
			</button>
			<button class="bt" data-tool="text" id="toolText" title="text" aria-label="text">
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 7 4 4 20 4 20 7"></polyline><line x1="9" y1="20" x2="15" y2="20"></line><line x1="12" y1="4" x2="12" y2="20"></line></svg>
			</button>
			<button class="bt" data-tool="pan" id="toolPan" title="move / pan" aria-label="pan">
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M5 9l-3 3 3 3M9 5l3-3 3 3M15 19l-3 3-3-3M19 9l3 3-3 3M2 12h20M12 2v20"></path></svg>
			</button>
		</div>
		<div class="board-group board-colors" id="boardColors">
			{PALETTE.map((c, i) => (
				<button class:list={["sw", { active: i === 0 }]} data-c={c} style={`--c:${c}`} title={c} aria-label={`colour ${c}`}></button>
			))}
			<button class="sw sw-custom" id="boardCustom" title="custom colour" aria-label="custom colour">
				<input id="boardCustomInput" type="color" value="#1d1c18" aria-label="pick custom colour" />
			</button>
		</div>
		<div class="board-group board-sizes">
			<button class="bs" data-size="4" title="thin"><i style="width:4px;height:4px"></i></button>
			<button class="bs active" data-size="9" title="medium"><i style="width:9px;height:9px"></i></button>
			<button class="bs" data-size="20" title="thick"><i style="width:18px;height:18px"></i></button>
		</div>
		<div class="board-group">
			<button class="bt" id="boardUndo" title="undo my last" aria-label="undo">
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7v6h6"></path><path d="M3.5 13a9 9 0 1 0 2.5-8.5L3 7"></path></svg>
			</button>
			<button class="bt" id="boardClear" title="clear board (owner)" aria-label="clear board">
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
			</button>
		</div>
		<span class="board-status" id="boardStatus" title="storage mode">local</span>
		<button class="bt board-x" id="boardClose" title="close" aria-label="close board">✕</button>
	</div>

	<div class="board-stage" id="boardStage">
		<canvas id="boardCanvas" width="2400" height="1600"></canvas>
		<input class="board-textin" id="boardTextIn" type="text" maxlength="120" placeholder="type, then ↵" aria-label="note text" />
	</div>

	<p class="board-hint" id="boardHint">draw &amp; write freely · scroll or two fingers to pan &amp; zoom · everyone shares this canvas</p>
</div>

<style>
.board {
	position: fixed; inset: 0; z-index: 380; display: none; flex-direction: column;
	background: var(--paper, #faf8f2); color: var(--fg, #1d1c18);
}
.board.show { display: flex; }

/* toolbar */
.board-bar {
	display: flex; align-items: center; flex-wrap: wrap; gap: 0.5rem;
	padding: 0.6rem 0.9rem; border-bottom: 1px solid var(--line, rgba(40,36,28,0.1));
	background: color-mix(in srgb, var(--paper, #faf8f2) 88%, transparent);
	backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px);
}
.board-title {
	font-family: var(--display, sans-serif); font-weight: 800; font-size: 0.95rem;
	margin-right: 0.4rem; letter-spacing: -0.01em;
}
.board-group { display: flex; align-items: center; gap: 0.3rem; padding-right: 0.5rem; border-right: 1px solid var(--line, rgba(40,36,28,0.1)); }
.board-group:last-of-type { border-right: none; }

.bt {
	display: flex; align-items: center; justify-content: center;
	width: 2rem; height: 2rem; padding: 0; border-radius: 0.55rem;
	border: 1px solid var(--line, rgba(40,36,28,0.12)); background: transparent;
	color: var(--muted, #8a877b); cursor: pointer;
	transition: color 0.15s ease, border-color 0.15s ease, background 0.15s ease;
}
.bt svg { width: 1.05rem; height: 1.05rem; }
.bt:hover { color: var(--fg, #1d1c18); border-color: var(--ink, #25324d); }
.bt.active { color: var(--ink, #25324d); border-color: var(--ink, #25324d); background: var(--ink-soft, rgba(37,50,77,0.09)); }
.board-x { margin-left: auto; font-size: 0.85rem; }

/* colour swatches */
.board-colors { flex-wrap: wrap; max-width: 11rem; }
.sw {
	width: 1.2rem; height: 1.2rem; border-radius: 50%; padding: 0;
	border: 2px solid transparent; cursor: pointer; background: var(--c);
	box-shadow: inset 0 0 0 1px rgba(0,0,0,0.12);
	transition: transform 0.14s ease;
}
.sw:hover { transform: scale(1.18); }
.sw.active { border-color: var(--fg, #1d1c18); transform: scale(1.08); }
.sw-custom { position: relative; overflow: hidden; background: conic-gradient(red, yellow, lime, aqua, blue, magenta, red); }
.sw-custom input { position: absolute; inset: -4px; opacity: 0; cursor: pointer; }

/* brush sizes */
.bs {
	display: flex; align-items: center; justify-content: center;
	width: 1.7rem; height: 1.7rem; border-radius: 0.5rem; padding: 0;
	border: 1px solid var(--line, rgba(40,36,28,0.12)); background: transparent; cursor: pointer;
	transition: border-color 0.15s ease;
}
.bs i { display: block; border-radius: 50%; background: var(--fg, #1d1c18); }
.bs:hover, .bs.active { border-color: var(--ink, #25324d); }
.bs.active i { background: var(--ink, #25324d); }

.board-status {
	font-family: var(--mono, monospace); font-size: 0.62rem; letter-spacing: 0.08em;
	text-transform: uppercase; color: var(--muted2, #b6b1a0); padding: 0.2rem 0.5rem;
	border: 1px solid var(--line, rgba(40,36,28,0.12)); border-radius: 999px;
}
.board-status.live { color: var(--ink, #25324d); border-color: var(--ink, #25324d); }
.board-status.saving { color: var(--muted, #8a877b); }

/* stage + canvas */
.board-stage {
	position: relative; flex: 1; overflow: hidden; touch-action: none;
	background:
		linear-gradient(45deg, rgba(0,0,0,0.025) 25%, transparent 25%, transparent 75%, rgba(0,0,0,0.025) 75%) 0 0 / 28px 28px,
		linear-gradient(45deg, rgba(0,0,0,0.025) 25%, transparent 25%, transparent 75%, rgba(0,0,0,0.025) 75%) 14px 14px / 28px 28px;
	cursor: crosshair;
}
#boardCanvas {
	position: absolute; top: 0; left: 0; transform-origin: 0 0;
	background: #fffdf7;
	box-shadow: 0 8px 40px rgba(0,0,0,0.18); image-rendering: auto;
}
[data-theme="dark"] #boardCanvas { background: #1c1c20; }
.board-textin {
	position: fixed; display: none; z-index: 5; min-width: 8rem;
	font-family: var(--sans, sans-serif); font-size: 1rem; padding: 0.35rem 0.5rem;
	border: 1.5px solid var(--ink, #25324d); border-radius: 0.4rem;
	background: var(--paper, #fff); color: var(--fg, #111); outline: none;
}
.board-textin.show { display: block; }

.board-hint {
	padding: 0.5rem 0.9rem; font-family: var(--mono, monospace); font-size: 0.64rem;
	color: var(--muted2, #b6b1a0); border-top: 1px solid var(--line, rgba(40,36,28,0.1));
	text-align: center;
}
@media (max-width: 600px) { .board-hint { font-size: 0.58rem; } .board-title { display: none; } }
</style>

<script is:inline>
(function () {
	/* ════════════════════════════════════════════════════════════════════
	 *  SUPABASE — paste your project URL + anon (public) key here.
	 *  Leave blank to run in local-only mode (saves to this browser only).
	 *  Setup SQL lives in the project README / chat.
	 * ════════════════════════════════════════════════════════════════════ */
	const SUPABASE_URL = 'https://bhxlcqlnbcorfiknblpv.supabase.co';
	const SUPABASE_ANON_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImJoeGxjcWxuYmNvcmZpa25ibHB2Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODA0MTA5NDgsImV4cCI6MjA5NTk4Njk0OH0.WoW5Dvl5ldUkILHp2TfHUJpmHPfeZnhhv78cFrRIvzU';

	const REMOTE = !!(SUPABASE_URL && SUPABASE_ANON_KEY);
	let sb = null;

	function loadSupabase() {
		return new Promise((res, rej) => {
			if (window.supabase) return res(window.supabase);
			const s = document.createElement('script');
			s.src = 'https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2';
			s.onload = () => res(window.supabase); s.onerror = rej;
			document.head.appendChild(s);
		});
	}
	async function storeInit() { if (REMOTE && !sb) { const lib = await loadSupabase(); sb = lib.createClient(SUPABASE_URL, SUPABASE_ANON_KEY); } }
	async function storeLoad() {
		if (REMOTE) {
			const { data, error } = await sb.from('board').select('png,version').eq('id', 1).single();
			if (error) throw error;
			return { png: data.png || null, version: Number(data.version) };
		}
		return { png: localStorage.getItem('board_png') || null, version: Number(localStorage.getItem('board_version') || 0) };
	}
	async function storeSave(png, expected) {
		if (REMOTE) {
			const { data, error } = await sb.rpc('board_save', { p_png: png, p_expected: expected });
			if (error) throw error;
			const row = Array.isArray(data) ? data[0] : data;
			return { ok: row.ok, version: Number(row.version), png: row.png || null };
		}
		localStorage.setItem('board_png', png);
		const v = expected + 1; localStorage.setItem('board_version', String(v));
		return { ok: true, version: v, png: null };
	}
	async function storeClear(secret) {
		if (REMOTE) {
			const { data, error } = await sb.rpc('board_clear', { p_secret: secret });
			if (error) throw error;
			const row = Array.isArray(data) ? data[0] : data;
			return !!row.ok;
		}
		localStorage.removeItem('board_png');
		localStorage.setItem('board_version', String(Number(localStorage.getItem('board_version') || 0) + 1));
		return true;
	}

	/* ── elements ─────────────────────────────────────────────────────── */
	const wrap = document.getElementById('board');
	const stage = document.getElementById('boardStage');
	const canvas = document.getElementById('boardCanvas');
	const ctx = canvas.getContext('2d');
	const statusEl = document.getElementById('boardStatus');
	const textIn = document.getElementById('boardTextIn');
	const W = canvas.width, H = canvas.height;

	/* offscreen "base" = the shared image as last seen from the store */
	const base = document.createElement('canvas'); base.width = W; base.height = H;
	const bctx = base.getContext('2d');

	/* ── state ────────────────────────────────────────────────────────── */
	const PALETTE = ['#1d1c18','#5b5650','#ffffff','#e5484d','#f76b15','#ffb224',
		'#46a758','#12a594','#2a4bd0','#6a35c9','#e93d82','#8a5a2b'];
	let tool = 'brush', color = '#1d1c18', size = 9;
	let pan = { x: 0, y: 0 }, zoom = 1;
	let myStrokes = [], cur = null, version = 0;
	let open = false, pollTimer = 0, saveTimer = 0, saving = false;
	let gesturePan = null, pendText = null;
	const pointers = new Map();
	let gesture = null;

	/* ── colour + size toolbars (swatches rendered server-side) ───────── */
	function setColor(c, el) { color = c; document.querySelectorAll('#boardColors .sw').forEach(s => s.classList.remove('active')); if (el) el.classList.add('active'); }
	document.querySelectorAll('#boardColors .sw[data-c]').forEach(b => b.addEventListener('click', () => setColor(b.dataset.c, b)));
	const customWrap = document.getElementById('boardCustom');
	const customIn = document.getElementById('boardCustomInput');
	customIn.addEventListener('input', () => setColor(customIn.value, customWrap));

	document.querySelectorAll('.bs').forEach(b => b.addEventListener('click', () => {
		size = Number(b.dataset.size); document.querySelectorAll('.bs').forEach(x => x.classList.remove('active')); b.classList.add('active');
	}));
	document.querySelectorAll('.bt[data-tool]').forEach(b => b.addEventListener('click', () => setTool(b.dataset.tool)));
	function setTool(t) {
		tool = t; document.querySelectorAll('.bt[data-tool]').forEach(x => x.classList.toggle('active', x.dataset.tool === t));
		stage.style.cursor = t === 'pan' ? 'grab' : (t === 'text' ? 'text' : 'crosshair');
		hideTextInput();
	}

	/* ── transform / coordinate mapping ───────────────────────────────── */
	function applyTransform() { canvas.style.transform = 'translate(' + pan.x + 'px,' + pan.y + 'px) scale(' + zoom + ')'; }
	function fit() {
		const r = stage.getBoundingClientRect();
		zoom = Math.min(r.width / W, r.height / H) * 0.92;
		pan.x = (r.width - W * zoom) / 2; pan.y = (r.height - H * zoom) / 2;
		applyTransform(); fitted = true;
	}
	function toBoard(cx, cy) { const r = stage.getBoundingClientRect(); return { x: (cx - r.left - pan.x) / zoom, y: (cy - r.top - pan.y) / zoom }; }

	/* ── rendering ────────────────────────────────────────────────────── */
	function setBase(png) {
		return new Promise(res => {
			bctx.clearRect(0, 0, W, H);
			if (!png) { render(); return res(); }
			const img = new Image();
			img.onload = () => { bctx.drawImage(img, 0, 0, W, H); render(); res(); };
			img.onerror = () => { render(); res(); };
			img.src = png;
		});
	}
	function strokePath(c, pts) {
		if (pts.length === 1) { c.beginPath(); c.arc(pts[0].x, pts[0].y, Math.max(0.5, c.lineWidth / 2), 0, 7); c.fill(); return; }
		c.beginPath(); c.moveTo(pts[0].x, pts[0].y);
		for (let i = 1; i < pts.length - 1; i++) { const mx = (pts[i].x + pts[i + 1].x) / 2, my = (pts[i].y + pts[i + 1].y) / 2; c.quadraticCurveTo(pts[i].x, pts[i].y, mx, my); }
		c.lineTo(pts[pts.length - 1].x, pts[pts.length - 1].y); c.stroke();
	}
	function drawStroke(c, st) {
		c.lineCap = 'round'; c.lineJoin = 'round';
		if (st.type === 'text') { c.fillStyle = st.color; c.font = st.font; c.textBaseline = 'top'; c.fillText(st.text, st.x, st.y); return; }
		c.strokeStyle = st.color; c.fillStyle = st.color; c.lineWidth = st.size; strokePath(c, st.pts);
	}
	function render() { ctx.clearRect(0, 0, W, H); ctx.drawImage(base, 0, 0); for (const st of myStrokes) drawStroke(ctx, st); }

	/* ── save (compose base+mine → png → atomic CAS) ──────────────────── */
	function scheduleSave() { clearTimeout(saveTimer); saveTimer = setTimeout(saveNow, 1100); }
	async function saveNow() {
		if (saving || !myStrokes.length) return;
		saving = true; setStatus('saving');
		try {
			render();
			const png = canvas.toDataURL('image/png');
			const res = await storeSave(png, version);
			if (res.ok) {
				bctx.clearRect(0, 0, W, H); bctx.drawImage(canvas, 0, 0); /* committed → new base */
				myStrokes = []; version = res.version;
			} else {
				await setBase(res.png); version = res.version; /* someone else saved: rebase, keep mine */
				clearTimeout(saveTimer); saveTimer = setTimeout(saveNow, 400);
			}
		} catch (e) { console.warn('board save failed', e); }
		saving = false; setStatus();
	}
	async function poll() {
		if (!open || saving) return;
		try { const r = await storeLoad(); if (r.version !== version) { version = r.version; await setBase(r.png); } } catch (e) {}
	}
	function setStatus(s) {
		if (s === 'saving') { statusEl.textContent = 'saving…'; statusEl.className = 'board-status saving'; return; }
		statusEl.textContent = REMOTE ? 'live' : 'local';
		statusEl.className = 'board-status' + (REMOTE ? ' live' : '');
	}

	/* ── pointer input: draw · pan · pinch-zoom ───────────────────────── */
	function midDist(ps) {
		const a = ps[0], b = ps[1];
		return { mx: (a.x + b.x) / 2, my: (a.y + b.y) / 2, d: Math.hypot(a.x - b.x, a.y - b.y) };
	}
	stage.addEventListener('pointerdown', e => {
		if (e.target === textIn) return;
		try { stage.setPointerCapture(e.pointerId); } catch (_) {}
		pointers.set(e.pointerId, { x: e.clientX, y: e.clientY });
		if (pointers.size === 2) { if (cur) { cur = null; scheduleSave(); } gesture = midDist([...pointers.values()]); return; }
		if (pointers.size > 2) return;
		if (tool === 'pan') { gesturePan = { x: e.clientX, y: e.clientY }; return; }
		if (tool === 'text') return;
		const p = toBoard(e.clientX, e.clientY);
		cur = { type: 'brush', color, size, pts: [p] }; myStrokes.push(cur);
		ctx.strokeStyle = color; ctx.fillStyle = color; ctx.lineWidth = size; ctx.lineCap = 'round'; ctx.lineJoin = 'round';
		ctx.beginPath(); ctx.arc(p.x, p.y, Math.max(0.5, size / 2), 0, 7); ctx.fill();
	});
	stage.addEventListener('pointermove', e => {
		if (!pointers.has(e.pointerId)) return;
		pointers.set(e.pointerId, { x: e.clientX, y: e.clientY });
		if (pointers.size >= 2 && gesture) {
			const g = midDist([...pointers.values()]);
			const r = stage.getBoundingClientRect();
			const bx = (gesture.mx - r.left - pan.x) / zoom, by = (gesture.my - r.top - pan.y) / zoom;
			zoom = Math.min(8, Math.max(0.1, zoom * (g.d / (gesture.d || g.d))));
			pan.x = g.mx - r.left - bx * zoom; pan.y = g.my - r.top - by * zoom;
			gesture = g; applyTransform(); return;
		}
		if (tool === 'pan' && pointers.size === 1) {
			const prev = gesturePan; if (prev) { pan.x += e.clientX - prev.x; pan.y += e.clientY - prev.y; applyTransform(); }
			gesturePan = { x: e.clientX, y: e.clientY }; return;
		}
		if (!cur) return;
		const p = toBoard(e.clientX, e.clientY), last = cur.pts[cur.pts.length - 1];
		cur.pts.push(p);
		ctx.strokeStyle = cur.color; ctx.lineWidth = cur.size; ctx.lineCap = 'round'; ctx.lineJoin = 'round';
		ctx.beginPath(); ctx.moveTo(last.x, last.y); ctx.lineTo(p.x, p.y); ctx.stroke();
	});
	function endPointer(e) {
		pointers.delete(e.pointerId); gesturePan = null;
		if (pointers.size < 2) gesture = null;
		if (cur) { cur = null; scheduleSave(); }
	}
	stage.addEventListener('pointerup', endPointer);
	stage.addEventListener('pointercancel', endPointer);

	/* tap with text tool → place a note */
	stage.addEventListener('click', e => {
		if (tool !== 'text' || e.target === textIn) return;
		pendText = toBoard(e.clientX, e.clientY);
		textIn.style.left = e.clientX + 'px'; textIn.style.top = e.clientY + 'px';
		textIn.value = ''; textIn.classList.add('show'); setTimeout(() => textIn.focus(), 0);
	});
	textIn.addEventListener('keydown', e => {
		if (e.key === 'Enter' && textIn.value.trim() && pendText) {
			const px = Math.max(14, size * 3.2);
			myStrokes.push({ type: 'text', text: textIn.value.trim(), x: pendText.x, y: pendText.y, color, font: '600 ' + px + 'px "Hanken Grotesk", sans-serif' });
			render(); scheduleSave(); hideTextInput();
		} else if (e.key === 'Escape') hideTextInput();
	});
	function hideTextInput() { textIn.classList.remove('show'); textIn.blur(); pendText = null; }

	/* wheel zoom (desktop) */
	stage.addEventListener('wheel', e => {
		e.preventDefault();
		const r = stage.getBoundingClientRect();
		const bx = (e.clientX - r.left - pan.x) / zoom, by = (e.clientY - r.top - pan.y) / zoom;
		zoom = Math.min(8, Math.max(0.1, zoom * (e.deltaY < 0 ? 1.12 : 0.89)));
		pan.x = e.clientX - r.left - bx * zoom; pan.y = e.clientY - r.top - by * zoom; applyTransform();
	}, { passive: false });

	/* ── toolbar buttons ──────────────────────────────────────────────── */
	document.getElementById('boardUndo').addEventListener('click', () => { if (myStrokes.length) { myStrokes.pop(); render(); scheduleSave(); } });
	document.getElementById('boardClear').addEventListener('click', async () => {
		const secret = prompt('owner secret to wipe the whole board:');
		if (secret == null) return;
		const ok = await storeClear(secret);
		if (ok) { myStrokes = []; const r = await storeLoad(); version = r.version; await setBase(r.png); }
		else alert('wrong secret — board not cleared.');
	});
	document.getElementById('boardClose').addEventListener('click', close);
	document.addEventListener('keydown', e => { if (open && e.key === 'Escape' && document.activeElement !== textIn) close(); });

	/* ── open / close ─────────────────────────────────────────────────── */
	async function openBoard() {
		if (open) return;
		open = true; wrap.classList.add('show'); wrap.setAttribute('aria-hidden', 'false');
		setStatus(); setTool('brush');
		try { await storeInit(); const r = await storeLoad(); version = r.version; await setBase(r.png); }
		catch (e) { console.warn('board load failed', e); statusEl.textContent = 'offline'; }
		requestAnimationFrame(() => { fit(); });
		clearInterval(pollTimer); pollTimer = setInterval(poll, 4000);
	}
	function close() { open = false; wrap.classList.remove('show'); wrap.setAttribute('aria-hidden', 'true'); clearInterval(pollTimer); hideTextInput(); }

	window.Board = { open: openBoard, close };
	const link = document.getElementById('boardLink');
	if (link) link.addEventListener('click', openBoard);
})();
</script>
