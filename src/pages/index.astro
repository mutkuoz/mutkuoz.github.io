	/* —— sky keyframes, day → night (top colour, bottom colour) —— */
	const SKY = [
		{ p: 0.00, t: [154,198,235], b: [226,234,228] }, // clear day
		{ p: 0.26, t: [120,168,214], b: [245,210,156] }, // afternoon, warming horizon
		{ p: 0.46, t: [120,112,168], b: [248,150, 96] }, // golden hour
		{ p: 0.64, t: [ 78, 60,116], b: [203, 98,112] }, // sunset rose
		{ p: 0.82, t: [ 28, 26, 60], b: [ 70, 40, 84] }, // dusk indigo
		{ p: 1.00, t: [  5,  6, 16], b: [ 12, 12, 30] }, // deep night
