<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
	--serif:   'Newsreader', Georgia, 'Times New Roman', serif;
	--display: 'Playfair Display', Georgia, 'Times New Roman', serif;
	/* alias consumed by snake canvas */
	--ink: var(--fg);
}

/* ── pure black / white theming ────────────────────────────────────── */
[data-theme="light"] {
	--bg:#ffffff; --fg:#000000;
	--fg2:rgba(0,0,0,0.74); --muted:rgba(0,0,0,0.52); --muted2:rgba(0,0,0,0.36);
	--hair:rgba(0,0,0,0.16);
}
[data-theme="dark"] {
	--bg:#000000; --fg:#ffffff;
	--fg2:rgba(255,255,255,0.78); --muted:rgba(255,255,255,0.54); --muted2:rgba(255,255,255,0.38);
	--hair:rgba(255,255,255,0.20);
}

html { scroll-behavior: smooth; }

body {
	font-family: var(--serif);
	font-optical-sizing: auto;
	text-transform: lowercase;
	color: var(--fg);
	background: var(--bg);
	-webkit-font-smoothing: antialiased;
	-moz-osx-font-smoothing: grayscale;
	transition: background-color 0.35s ease, color 0.35s ease;
	min-height: 100vh;
	line-height: 1.5;
}

::selection { background: var(--fg); color: var(--bg); }

/* ── reading progress ──────────────────────────────────────────────── */
#scrollProgress {
	position: fixed; top: 0; left: 0; height: 2px; width: 0;
	background: var(--fg); z-index: 200; opacity: 0.6;
}

/* ── navbar ────────────────────────────────────────────────────────── */
#navbar {
	position: fixed; top: 0; left: 0; right: 0; z-index: 100;
	display: flex; align-items: center; justify-content: space-between;
	gap: 1rem; height: 3.4rem; padding: 0 1.3rem;
	background: color-mix(in srgb, var(--bg) 86%, transparent);
	backdrop-filter: blur(7px); -webkit-backdrop-filter: blur(7px);
	border-bottom: 1px solid var(--hair);
	transition: background 0.35s ease, border-color 0.35s ease;
}
@media (min-width: 720px) { #navbar { padding: 0 2rem; } }
.nav-brand {
	font-family: var(--display); font-style: italic; font-weight: 600;
	font-size: 1.02rem; color: var(--fg); text-decoration: none; white-space: nowrap;
}
.nav-links { display: none; gap: 1.6rem; margin-left: auto; margin-right: 1.3rem; }
@media (min-width: 700px) { .nav-links { display: flex; } }
.nav-link {
	font-family: var(--serif); font-size: 0.86rem; letter-spacing: 0.02em;
	color: var(--muted); text-decoration: none;
	position: relative; padding-bottom: 2px; transition: color 0.18s ease;
}
.nav-link::after {
	content: ''; position: absolute; left: 0; right: 100%; bottom: 0; height: 1px;
	background: var(--fg); transition: right 0.25s cubic-bezier(0.4,0,0.2,1);
}
.nav-link:hover { color: var(--fg); }
.nav-link:hover::after { right: 0; }

.mode-toggle {
	display: flex; align-items: center; justify-content: center;
	width: 2rem; height: 2rem; border-radius: 50%;
	border: 1px solid var(--hair); background: transparent; cursor: pointer; color: var(--fg);
	transition: border-color 0.2s ease, transform 0.4s cubic-bezier(0.34,1.4,0.64,1);
}
.mode-toggle:hover { border-color: var(--fg); transform: rotate(-22deg); }
.mode-toggle:focus-visible { outline: 2px solid var(--fg); outline-offset: 2px; }
.mode-toggle svg { width: 0.95rem; height: 0.95rem; }
[data-theme="light"] .icon-moon { display: none; }
[data-theme="dark"]  .icon-sun  { display: none; }

/* ── page column (wider) ───────────────────────────────────────────── */
.paper {
	max-width: 80rem; margin: 0 auto;
	padding: 6rem 1.3rem 4rem;
}
@media (min-width: 720px) { .paper { padding: 7rem 2.4rem 5rem; } }
.section { scroll-margin-top: 4.5rem; margin-top: 3.4rem; }

/* ── masthead ──────────────────────────────────────────────────────── */
.masthead { border-bottom: 1px solid var(--hair); padding-bottom: 1.2rem; }
.dateline {
	display: flex; align-items: center; justify-content: space-between; gap: 0.6rem;
	font-size: 0.72rem; letter-spacing: 0.05em; color: var(--muted); margin-bottom: 0.9rem;
}
.nameplate {
	font-family: var(--display); font-weight: 700;
	font-size: clamp(2.4rem, 8vw, 5rem); line-height: 1; text-align: center;
	letter-spacing: -0.02em;
}

/* ── lead block ────────────────────────────────────────────────────── */
.lead { display: grid; grid-template-columns: 1fr; gap: 2rem; margin-top: 2.2rem; }
@media (min-width: 840px) {
	.lead { grid-template-columns: 1.5fr 1fr; gap: 1.5rem; align-items: start; }
	/* pull the cutout toward the text — at head height its left side is empty,
	   so it overlaps the gap invisibly; shoulders sit below the text. */
	.lead-aside .fig { margin-left: -3.5rem; margin-right: -1.5rem; max-width: 30rem; }
}
.standfirst {
	font-size: clamp(1.15rem, 1.7vw, 1.5rem); line-height: 1.8; color: var(--fg);
	text-align: justify; hyphens: auto;
}

/* portrait — transparent line-art cutout, floats on the page */
.fig { margin: 0 auto; max-width: 22rem; }
.fig-slot { position: relative; }
.fig-slot img { display: block; width: 100%; height: auto; }
/* black engraving would vanish on a black page — invert it in dark mode */
[data-theme="dark"] .fig-slot img { filter: invert(1); }
figcaption {
	font-style: italic; font-size: 0.82rem; color: var(--muted);
	padding-top: 0.5rem; margin-top: 0.5rem; border-top: 1px solid var(--hair); line-height: 1.5;
}
.cap-soft { color: var(--muted2); }

/* ── section rule-head (quiet) ─────────────────────────────────────── */
.rule-head { margin-bottom: 1.4rem; padding-bottom: 0.45rem; border-bottom: 1px solid var(--hair); }
.rule-head-label { font-family: var(--serif); font-size: 1rem; font-weight: 600; letter-spacing: 0.01em; color: var(--fg); }

/* ── columns ───────────────────────────────────────────────────────── */
.cols-2 { display: grid; grid-template-columns: 1fr; }
@media (min-width: 760px) { .cols-2 { grid-template-columns: 1fr 1fr; column-gap: 3.2rem; } }

/* ── expandable item ───────────────────────────────────────────────── */
.item { border-top: 1px solid var(--hair); }
.col > .item:first-child, .papers > .item:first-child { border-top: none; }
@media (max-width: 759px) { .col + .col > .item:first-child { border-top: 1px solid var(--hair); } }

.item-head {
	display: grid; grid-template-columns: 1fr auto; grid-template-areas: "title plus" "byline plus";
	gap: 0 0.8rem; align-items: start; width: 100%; text-align: left;
	background: none; border: none; cursor: pointer; color: inherit; font-family: inherit;
	padding: 0.95rem 0; transition: padding-left 0.25s cubic-bezier(0.4,0,0.2,1);
}
.item-head:hover { padding-left: 0.4rem; }
.item-head:focus-visible { outline: 2px solid var(--fg); outline-offset: 2px; }
.item-title {
