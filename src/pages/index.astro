		<p class="snake-over-t">game over</p>
		<p class="snake-over-s">score <b id="snakeFinal">0</b></p>
		<button class="snake-btn" id="snakeRetry">play again</button>
	</div>
</div>

<!-- ═══ STYLES ════════════════════════════════════════════════════════════ -->
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
	--sans:    'Hanken Grotesk', system-ui, -apple-system, sans-serif;
	--display: 'Schibsted Grotesk', 'Hanken Grotesk', system-ui, sans-serif;
	--mono:    'Spline Sans Mono', ui-monospace, monospace;
}

/* ── ink (your pen) ────────────────────────────────────────────────── */
[data-ink="blueblack"] { --ink:#25324d; --ink-soft:rgba(37,50,77,0.09); }
[data-ink="royal"]     { --ink:#2a4bd0; --ink-soft:rgba(42,75,208,0.10); }
[data-ink="red"]       { --ink:#c33125; --ink-soft:rgba(195,49,37,0.09); }
[data-ink="emerald"]   { --ink:#0c7a55; --ink-soft:rgba(12,122,85,0.10); }
[data-ink="violet"]    { --ink:#6a35c9; --ink-soft:rgba(106,53,201,0.10); }
[data-ink="sepia"]     { --ink:#8a5a2b; --ink-soft:rgba(138,90,43,0.11); }
[data-theme="dark"][data-ink="blueblack"] { --ink:#93a8d8; --ink-soft:rgba(147,168,216,0.13); }
[data-theme="dark"][data-ink="royal"]     { --ink:#7d97ff; --ink-soft:rgba(125,151,255,0.14); }
[data-theme="dark"][data-ink="red"]       { --ink:#ff8175; --ink-soft:rgba(255,129,117,0.13); }
[data-theme="dark"][data-ink="emerald"]   { --ink:#4fd3a0; --ink-soft:rgba(79,211,160,0.13); }
[data-theme="dark"][data-ink="violet"]    { --ink:#b48dff; --ink-soft:rgba(180,141,255,0.14); }
[data-theme="dark"][data-ink="sepia"]     { --ink:#dba968; --ink-soft:rgba(219,169,104,0.13); }

/* ── paper / ink tokens ────────────────────────────────────────────── */
[data-theme="light"] {
	--paper:#faf8f2; --rule:rgba(40,36,28,0.045);
	--fg:#1d1c18; --fg2:#4c4a42; --muted:#928d80; --muted2:#bdb7a8;
	--line:rgba(40,36,28,0.10);
}
[data-theme="dark"] {
	--paper:#17171a; --rule:rgba(220,222,235,0.038);
	--fg:#ecebe4; --fg2:#bdbcb2; --muted:#8a887e; --muted2:#56554d;
	--line:rgba(230,230,240,0.10);
}

html { scroll-behavior: smooth; }

body {
	font-family: var(--sans);
	color: var(--fg);
	background-color: var(--paper);
	/* whisper-faint ruling — the only notebook cue */
	background-image: repeating-linear-gradient(to bottom,
		transparent 0, transparent calc(2.1rem - 1px),
		var(--rule) calc(2.1rem - 1px), var(--rule) 2.1rem);
	background-position: 0 0.6rem;
	-webkit-font-smoothing: antialiased;
	-moz-osx-font-smoothing: grayscale;
	transition: background-color 0.4s ease, color 0.4s ease;
	min-height: 100vh;
}

/* ── ink trail / splatter canvas ───────────────────────────────────── */
#inkCanvas { position: fixed; inset: 0; z-index: 5; pointer-events: none; }

/* ── scroll progress ───────────────────────────────────────────────── */
#scrollProgress {
	position: fixed; top: 0; left: 0; height: 2px; width: 0;
	background: var(--ink); z-index: 200; transition: background 0.3s ease;
}

/* ── navbar ────────────────────────────────────────────────────────── */
#navbar {
	position: fixed; top: 0; left: 0; right: 0; z-index: 100;
	display: flex; align-items: center; justify-content: space-between;
	gap: 1rem; height: 3.6rem; padding: 0 1.4rem;
	background: color-mix(in srgb, var(--paper) 80%, transparent);
	backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
	transition: background 0.4s ease;
}
@media (min-width: 720px) { #navbar { padding: 0 2.4rem; } }

.nav-name {
	font-family: var(--display); font-size: 0.98rem; font-weight: 700;
	letter-spacing: -0.01em; color: var(--fg); text-decoration: none; white-space: nowrap;
	transition: color 0.2s ease;
}
.nav-name:hover { color: var(--ink); }

.nav-links { display: none; gap: 1.5rem; margin-left: auto; margin-right: 1.4rem; }
@media (min-width: 720px) { .nav-links { display: flex; } }
.nav-link {
	font-family: var(--mono); font-size: 0.72rem; color: var(--muted);
	text-decoration: none; position: relative; transition: color 0.18s ease;
}
.nav-link::after {
	content: ''; position: absolute; left: 0; right: 100%; bottom: -3px; height: 1.5px;
	background: var(--ink); transition: right 0.25s cubic-bezier(0.4,0,0.2,1);
}
.nav-link:hover { color: var(--fg); }
.nav-link:hover::after { right: 0; }

.nav-controls { display: flex; align-items: center; gap: 0.6rem; }

/* pen picker */
.pen-wrap { position: relative; }
.pen-btn {
	display: flex; align-items: center; justify-content: center;
	width: 1.9rem; height: 1.9rem; border-radius: 50%;
	border: 1px solid var(--line); background: transparent; cursor: pointer;
	transition: border-color 0.2s ease, transform 0.3s ease;
}
.pen-btn:hover { border-color: var(--ink); transform: rotate(-12deg); }
.pen-btn:focus-visible { outline: 2px solid var(--ink); outline-offset: 2px; }
.pen-swatch { width: 0.85rem; height: 0.85rem; border-radius: 50%; background: var(--ink); box-shadow: 0 0 0 2px var(--ink-soft); transition: background 0.3s ease; }

.pen-pop {
	position: absolute; top: calc(100% + 0.5rem); right: 0;
	display: flex; gap: 0.5rem; padding: 0.6rem;
	background: var(--paper); border: 1px solid var(--line); border-radius: 0.8rem;
	box-shadow: 0 12px 30px rgba(0,0,0,0.18);
	opacity: 0; transform: translateY(-6px) scale(0.96); transform-origin: top right;
	pointer-events: none; transition: opacity 0.18s ease, transform 0.18s cubic-bezier(0.34,1.4,0.64,1);
	z-index: 120;
}
.pen-pop.open { opacity: 1; transform: translateY(0) scale(1); pointer-events: auto; }
.nib { width: 1.1rem; height: 1.1rem; border-radius: 50%; background: var(--nib); border: 2px solid transparent; cursor: pointer; padding: 0; transition: transform 0.16s ease, border-color 0.16s ease; }
.nib:hover { transform: scale(1.2) rotate(-8deg); }
.nib.active { border-color: var(--fg); }
.nib:focus-visible { outline: 2px solid var(--fg); outline-offset: 2px; }

.mode-toggle {
