		if (a <= 0) return; ctx.save();
		const gl = ctx.createRadialGradient(x, y, 0, x, y, r * 5);
		gl.addColorStop(0, `rgba(255,240,200,${0.5 * a})`); gl.addColorStop(0.4, `rgba(255,210,140,${0.18 * a})`); gl.addColorStop(1, 'rgba(255,200,120,0)');
		ctx.fillStyle = gl; ctx.fillRect(x - r * 5, y - r * 5, r * 10, r * 10);
		ctx.save(); ctx.translate(x, y); ctx.rotate(T * 0.0002);   // slowly turning rays
		for (let i = 0; i < 12; i++) {
			ctx.rotate(Math.PI / 6);
			ctx.beginPath(); ctx.moveTo(r * 1.3, -r * 0.05); ctx.lineTo(r * 3.4, 0); ctx.lineTo(r * 1.3, r * 0.05); ctx.closePath();
			ctx.fillStyle = `rgba(255,228,170,${0.18 * a * df})`; ctx.fill();
		}
		ctx.restore();
		const dg = ctx.createRadialGradient(x - r * 0.3, y - r * 0.3, r * 0.2, x, y, r);
		dg.addColorStop(0, '#fff9e8'); dg.addColorStop(0.7, '#ffd98a'); dg.addColorStop(1, '#ffb866');
		ctx.globalAlpha = a; ctx.fillStyle = dg; ctx.beginPath(); ctx.arc(x, y, r, 0, 7); ctx.fill();
		ctx.restore();
	}
	function drawMoon(x, y, r, a) {
		if (a <= 0) return; ctx.save();
		const gl = ctx.createRadialGradient(x, y, 0, x, y, r * 4);
		gl.addColorStop(0, `rgba(220,228,255,${0.4 * a})`); gl.addColorStop(0.5, `rgba(180,195,235,${0.12 * a})`); gl.addColorStop(1, 'rgba(180,195,235,0)');
		ctx.fillStyle = gl; ctx.fillRect(x - r * 4, y - r * 4, r * 8, r * 8);
		const dg = ctx.createRadialGradient(x - r * 0.35, y - r * 0.35, r * 0.2, x, y, r);
		dg.addColorStop(0, '#ffffff'); dg.addColorStop(0.7, '#e8ecf6'); dg.addColorStop(1, '#c2c9da');
		ctx.globalAlpha = a; ctx.fillStyle = dg; ctx.beginPath(); ctx.arc(x, y, r, 0, 7); ctx.fill();
		ctx.fillStyle = 'rgba(150,158,180,0.5)';
		[[-.3,-.2,.18],[.25,.1,.22],[.05,.38,.14],[.38,-.3,.12],[-.2,.32,.1]].forEach(c => {
			ctx.beginPath(); ctx.arc(x + c[0] * r, y + c[1] * r, c[2] * r, 0, 7); ctx.fill();
		});
		ctx.restore();
	}
	function drawHills(nf) {
		hills.forEach(h => {
			ctx.fillStyle = rgb(mix(h.col, [4,5,12], nf));
			ctx.beginPath(); ctx.moveTo(0, H); ctx.lineTo(h.pts[0][0], h.pts[0][1]);
			for (let i = 1; i < h.pts.length; i++) ctx.lineTo(h.pts[i][0], h.pts[i][1]);
			ctx.lineTo(W, H); ctx.closePath(); ctx.fill();
		});
	}
	function puff(x, y, u) {
		[[0,0,1.4,0.8],[-1.1,0.25,1,0.7],[1.1,0.3,1.05,0.7],[-0.5,-0.4,0.95,0.7],[0.55,-0.35,1,0.7]].forEach(p => {
			ctx.beginPath(); ctx.ellipse(x + p[0] * u, y + p[1] * u, p[2] * u, p[3] * u, 0, 0, 7); ctx.fill();
		});
	}
	function drawClouds(now, df, bot) {
		const a0 = clamp(df, 0, 1); if (a0 <= 0.02) return;
		ctx.save(); ctx.fillStyle = rgb(mix(bot, [255,255,255], 0.5));
		for (const c of clouds) {
			const x = ((c.x + now * c.spd) % (W + 300)) - 150;
			ctx.globalAlpha = c.a * a0 * 0.8; puff(x, c.y, 28 * c.s);
		}
		ctx.restore();
	}
	function drawMotes(now, nf) {
		for (const m of motes) {
			const x = m.x + Math.sin(now * 0.0003 * m.s + m.ph) * 28;
			const y = m.y + Math.cos(now * 0.00025 * m.s + m.ph) * 20;
			const tw = 0.4 + 0.6 * Math.abs(Math.sin(now * 0.0012 * m.s + m.ph));
			const a = tw * (0.5 * nf + 0.18 * (1 - nf)); if (a <= 0.02) continue;
			const col = nf > 0.5 ? [255,224,150] : [255,255,255];
			ctx.save(); ctx.globalAlpha = a;
			if (nf > 0.4) { // fireflies glow at night
				const g = ctx.createRadialGradient(x, y, 0, x, y, m.r * 4);
				g.addColorStop(0, rgb(col, 1)); g.addColorStop(1, rgb(col, 0));
				ctx.fillStyle = g; ctx.beginPath(); ctx.arc(x, y, m.r * 4, 0, 7); ctx.fill();
			} else {        // dust motes drift by day
				ctx.fillStyle = rgb(col); ctx.beginPath(); ctx.arc(x, y, m.r, 0, 7); ctx.fill();
			}
			ctx.restore();
		}
	}
	function drawVignette(nf) {
		const g = ctx.createRadialGradient(W / 2, H / 2, Math.min(W, H) * 0.3, W / 2, H / 2, Math.max(W, H) * 0.75);
		g.addColorStop(0, 'rgba(0,0,0,0)'); g.addColorStop(1, `rgba(0,0,0,${0.25 + 0.45 * nf})`);
		ctx.fillStyle = g; ctx.fillRect(0, 0, W, H);
	}
	function drawCaption(p) {
		for (const b of captionBeats) {
			const a = band(p, b.from, b.to, 0.06); if (a <= 0.01) continue;
			ctx.save(); ctx.globalAlpha = a; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
			ctx.font = `italic 500 ${Math.min(W * 0.05, 34)}px Newsreader, Georgia, serif`;
			ctx.fillStyle = 'rgba(255,255,255,0.95)'; ctx.shadowColor = 'rgba(0,0,0,0.6)'; ctx.shadowBlur = 18;
			ctx.fillText(b.text, W / 2, H * 0.4); ctx.restore();
		}
	}
	function drawSkipHint(p) {
		const a = clamp(1 - remap(p, 0.7, 0.95), 0, 1) * 0.5; if (a <= 0.02) return;
		ctx.save(); ctx.globalAlpha = a; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
		ctx.font = 'italic 400 13px Newsreader, Georgia, serif'; ctx.fillStyle = 'rgba(255,255,255,0.8)';
		ctx.fillText('click anywhere to skip', W / 2, H - 34); ctx.restore();
	}

	/* —— one frame of the whole production —— */
	function render(p, now) {
		T = now; ctx.clearRect(0, 0, W, H);
		const q  = dir === 1 ? p : 1 - p;                                   // sky progress, day(0)→night(1)
		const nf = dir === 1 ? remap(p, 0.46, 0.9) : 1 - remap(p, 0.08, 0.5); // night factor
		const df = 1 - nf;                                                  // day factor
		const sky = skyAt(q);

		const g = ctx.createLinearGradient(0, 0, 0, H);
		g.addColorStop(0, rgb(sky.top)); g.addColorStop(1, rgb(sky.bot));
		ctx.fillStyle = g; ctx.fillRect(0, 0, W, H);

		drawAurora(now, nf);
		drawStars(now, nf);
		drawConstellation(nf);
		drawShooters(p);

		// celestial trajectories: one body sets, the other rises
		const setP = easeInOut(remap(p, 0.04, 0.74));
		const risP = easeOut(remap(p, 0.42, 0.97));
		const m = Math.min(W, H);
		const setX = lerp(0.72 * W, 0.12 * W, setP), setY = lerp(0.24 * H, horizonY + 0.05 * H, Math.pow(setP, 1.7));
		const setR = m * 0.085, setA = 1 - remap(setP, 0.8, 1) * 0.55;
		const risX = lerp(0.85 * W, 0.60 * W, risP), risY = lerp(horizonY + 0.04 * H, 0.2 * H, risP);
		const risR = m * 0.07, risA = remap(risP, 0, 0.16);

		if (dir === 1) drawSun(setX, setY, setR, setA, df); else drawMoon(setX, setY, setR, setA);
		drawHills(nf);                                              // horizon occludes the setting body
		if (dir === 1) drawMoon(risX, risY, risR, risA); else drawSun(risX, risY, risR, risA, df);

		drawClouds(now, df, sky.bot);
		drawMotes(now, nf);
		drawVignette(nf);
		drawCaption(p);
		drawSkipHint(p);

		// the grand finale: iris the new, freshly-themed page out of the toggle button
		if (p > FLIP_AT) {
			const r = easeInOut(remap(p, FLIP_AT + 0.03, 0.99)) * maxR;
			ctx.save(); ctx.globalCompositeOperation = 'destination-out';
			const ag = ctx.createRadialGradient(bx, by, Math.max(0, r - 50), bx, by, r + 1);
			ag.addColorStop(0, 'rgba(0,0,0,1)'); ag.addColorStop(1, 'rgba(0,0,0,0)');
			ctx.fillStyle = ag; ctx.beginPath(); ctx.arc(bx, by, r + 1, 0, 7); ctx.fill();
			ctx.restore();
		}
	}

	function frame(now) {
		if (!running) return;
		const p = clamp((now - startT) / DURATION, 0, 1);
		render(p, now);
		if (!flipped && p >= FLIP_AT) { apply(toTheme); flipped = true; }
		if (p >= 1) { finish(); return; }
		raf = requestAnimationFrame(frame);
	}

	function finish() {
		if (!flipped) { apply(toTheme); flipped = true; }
		running = false; cancelAnimationFrame(raf);
		removeEventListener('resize', size);
		removeEventListener('keydown', onSkipKey, true);
		canvas.removeEventListener('click', skip);
		canvas.classList.remove('show'); canvas.setAttribute('aria-hidden', 'true');
		ctx.setTransform(1, 0, 0, 1, 0, 0); ctx.clearRect(0, 0, canvas.width, canvas.height);
		toggleBtn.classList.remove('casting'); toggleBtn.classList.add('landed');
		setTimeout(() => toggleBtn.classList.remove('landed'), 750);
	}

	// skip / fast-forward: race to the aperture reveal rather than cutting hard
	function skip() {
		if (!running) return;
		const now = performance.now(), cur = clamp((now - startT) / DURATION, 0, 1);
		if (cur < 0.9) startT = now - DURATION * 0.9;
	}
	function onSkipKey(e) {
		if (e.key === 'Escape' || e.key === 'Enter' || e.key === ' ') { if (e.key === ' ') e.preventDefault(); skip(); }
	}

	function play(next) {
		if (running) return;
		dir = next === 'dark' ? 1 : -1; toTheme = next; flipped = false; running = true;
		size(); build();
		toggleBtn.classList.remove('landed'); toggleBtn.classList.add('casting');
		canvas.classList.add('show'); canvas.setAttribute('aria-hidden', 'false');
		addEventListener('resize', size);
		addEventListener('keydown', onSkipKey, true);
		canvas.addEventListener('click', skip);
		startT = performance.now();
		raf = requestAnimationFrame(frame);
	}

	function toggle() {
		const cur = html.getAttribute('data-theme') === 'dark' ? 'dark' : 'light';
		const next = cur === 'dark' ? 'light' : 'dark';
		if (reduce.matches) { apply(next); return; }   // honour reduced-motion: just swap
		if (running) return;                            // ignore taps mid-cinematic
		play(next);
	}

	// restore saved theme instantly on load (no cinematic), then wire the button
	let saved = 'light';
	try { saved = localStorage.getItem('theme') || 'light'; } catch (e) {}
	apply(saved);
	toggleBtn.addEventListener('click', toggle);

	return { toggle };
})();

/* ── ink helper (foreground colour) for snake canvas ───────────────── */
function inkColor() {
	return getComputedStyle(document.documentElement).getPropertyValue('--fg').trim()
		|| (document.documentElement.getAttribute('data-theme') === 'dark' ? '#ffffff' : '#000000');
}

/* ── reveal on scroll ──────────────────────────────────────────────── */
(function () {
	const io = new IntersectionObserver(es => es.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); io.unobserve(e.target); } }), { threshold: 0.05 });
	document.querySelectorAll('.reveal').forEach((el, i) => { el.style.transitionDelay = (i * 0.04) + 's'; io.observe(el); });
})();

/* ── scroll progress ───────────────────────────────────────────────── */
(function () {
	const bar = document.getElementById('scrollProgress'); let raf = 0;
	function up() { const h = document.documentElement, m = h.scrollHeight - h.clientHeight; bar.style.width = (m > 0 ? (h.scrollTop / m) * 100 : 0) + '%'; raf = 0; }
	addEventListener('scroll', () => { if (!raf) raf = requestAnimationFrame(up); }, { passive: true }); up();
})();

/* ── SNAKE minigame ────────────────────────────────────────────────── */
const Snake = (function () {
	const wrap = document.getElementById('snake');
	const canvas = document.getElementById('snakeCanvas');
	const ctx = canvas.getContext('2d');
	const scoreEl = document.getElementById('snakeScore');
	const overEl = document.getElementById('snakeOver');
	const finalEl = document.getElementById('snakeFinal');
	const CELL = 26;
	let cols, rows, snake, dir, nextDir, food, score, dead, acc, lastT, raf = 0, running = false, ox = 0, oy = 0;

	function fit() {
		const dpr = Math.min(window.devicePixelRatio || 1, 2);
		canvas.width = innerWidth * dpr; canvas.height = innerHeight * dpr;
		canvas.style.width = innerWidth + 'px'; canvas.style.height = innerHeight + 'px';
		ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
		cols = Math.floor(innerWidth / CELL); rows = Math.floor(innerHeight / CELL);
		ox = (innerWidth - cols * CELL) / 2; oy = (innerHeight - rows * CELL) / 2;
	}
	function placeFood() {
		do { food = { x: (Math.random() * cols) | 0, y: (Math.random() * rows) | 0 }; }
		while (snake.some(s => s.x === food.x && s.y === food.y));
	}
	function reset() {
		fit();
		const cx = cols >> 1, cy = rows >> 1;
		snake = [{ x: cx, y: cy }, { x: cx - 1, y: cy }, { x: cx - 2, y: cy }];
		dir = { x: 1, y: 0 }; nextDir = dir; score = 0; dead = false; acc = 0; lastT = 0;
		scoreEl.textContent = '0'; overEl.classList.remove('show'); placeFood();
	}
	function step() {
		dir = nextDir;
		const head = { x: snake[0].x + dir.x, y: snake[0].y + dir.y };
		if (head.x < 0 || head.y < 0 || head.x >= cols || head.y >= rows || snake.some(s => s.x === head.x && s.y === head.y)) {
			dead = true; finalEl.textContent = score; overEl.classList.add('show'); return;
		}
		snake.unshift(head);
		if (head.x === food.x && head.y === food.y) { score++; scoreEl.textContent = score; placeFood(); }
		else snake.pop();
	}
	function cell(x, y) { return [ox + x * CELL, oy + y * CELL]; }
	function render() {
		ctx.clearRect(0, 0, innerWidth, innerHeight);
		const ink = inkColor();
		const [fx, fy] = cell(food.x, food.y);
		ctx.fillStyle = ink; ctx.globalAlpha = 0.85;
		ctx.beginPath(); ctx.arc(fx + CELL / 2, fy + CELL / 2, CELL * 0.22, 0, 7); ctx.fill();
		ctx.globalAlpha = 1; ctx.strokeStyle = ink; ctx.lineWidth = CELL * 0.5; ctx.lineJoin = 'round'; ctx.lineCap = 'round';
		ctx.beginPath();
		snake.forEach((s, i) => { const [x, y] = cell(s.x, s.y); const px = x + CELL / 2, py = y + CELL / 2; i ? ctx.lineTo(px, py) : ctx.moveTo(px, py); });
		ctx.stroke();
		const [hx, hy] = cell(snake[0].x, snake[0].y);
		ctx.fillStyle = ink; ctx.beginPath(); ctx.arc(hx + CELL / 2, hy + CELL / 2, CELL * 0.3, 0, 7); ctx.fill();
	}
	function loop(t) {
		if (!running) return;
		if (!lastT) lastT = t;
		const dt = t - lastT; lastT = t;
		if (!dead) {
			acc += dt; const speed = Math.max(70, 130 - score * 3);
			while (acc >= speed) { acc -= speed; step(); if (dead) break; }
			render();
		}
		raf = requestAnimationFrame(loop);
	}
	function onKey(e) {
		const k = e.key;
		if (k === 'Escape' || k === 'q') { stop(); return; }
		if (dead && (k === ' ' || k === 'Enter')) { e.preventDefault(); reset(); return; }
		let nd = null;
		if (k === 'ArrowUp' || k === 'w') nd = { x: 0, y: -1 };
		else if (k === 'ArrowDown' || k === 's') nd = { x: 0, y: 1 };
		else if (k === 'ArrowLeft' || k === 'a') nd = { x: -1, y: 0 };
		else if (k === 'ArrowRight' || k === 'd') nd = { x: 1, y: 0 };
		if (nd) { e.preventDefault(); if (nd.x !== -dir.x || nd.y !== -dir.y) nextDir = nd; }
	}
	let tsx = 0, tsy = 0, touching = false;
	function setDir(nd) { if (!dead && (nd.x !== -dir.x || nd.y !== -dir.y)) nextDir = nd; }
	function onTouchStart(e) { const t = e.touches[0]; tsx = t.clientX; tsy = t.clientY; touching = true; e.preventDefault(); }
	function onTouchMove(e) {
		if (!touching) return; e.preventDefault();
		const t = e.touches[0], dx = t.clientX - tsx, dy = t.clientY - tsy, TH = 22;
		if (Math.abs(dx) < TH && Math.abs(dy) < TH) return;
		if (Math.abs(dx) > Math.abs(dy)) setDir({ x: dx > 0 ? 1 : -1, y: 0 });
		else setDir({ x: 0, y: dy > 0 ? 1 : -1 });
		tsx = t.clientX; tsy = t.clientY;
	}
	function onTouchEnd() { touching = false; }
	function start() {
		if (running) return;
		running = true; wrap.classList.add('show'); wrap.setAttribute('aria-hidden', 'false');
		reset();
		document.addEventListener('keydown', onKey, true);
		canvas.addEventListener('touchstart', onTouchStart, { passive: false });
		canvas.addEventListener('touchmove', onTouchMove, { passive: false });
		canvas.addEventListener('touchend', onTouchEnd);
		addEventListener('resize', fit);
		lastT = 0; raf = requestAnimationFrame(loop);
		toast(matchMedia('(pointer: coarse)').matches ? 'snake — swipe to steer' : 'snake — esc to quit', 1700);
	}
	function stop() {
		running = false; wrap.classList.remove('show'); wrap.setAttribute('aria-hidden', 'true');
		cancelAnimationFrame(raf);
		document.removeEventListener('keydown', onKey, true);
		canvas.removeEventListener('touchstart', onTouchStart);
		canvas.removeEventListener('touchmove', onTouchMove);
		canvas.removeEventListener('touchend', onTouchEnd);
		removeEventListener('resize', fit);
	}
	document.getElementById('snakeRetry').addEventListener('click', reset);
	document.getElementById('snakeClose').addEventListener('click', stop);
	return { start, stop, isRunning() { return running; } };
})();
document.getElementById('playLink').addEventListener('click', () => Snake.start());

/* ── keyboard: d = day/night · type "snake" ────────────────────────── */
(function () {
	let buf = '';
	addEventListener('keydown', e => {
		const t = e.target;
		if (t && (t.tagName === 'INPUT' || t.tagName === 'TEXTAREA' || t.isContentEditable)) return;
		if (Snake.isRunning()) return;
		if (e.metaKey || e.ctrlKey || e.altKey) return;
		const kl = e.key.toLowerCase();
		if (kl === 'd') { ThemeCinema.toggle(); }
		if (/^[a-z]$/.test(kl)) {
			buf = (buf + kl).slice(-6);
			if (buf.endsWith('snake') || buf.endsWith('play')) { Snake.start(); buf = ''; }
		}
	});
})();
</script>

</body>
</html>
