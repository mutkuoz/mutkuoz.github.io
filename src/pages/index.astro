	display: inline-flex; align-items: baseline; gap: 0.5rem;
}
.item-byline {
	grid-area: byline; margin-top: 0.25rem;
	font-size: 0.74rem; letter-spacing: 0.02em; color: var(--muted);
}
.item-plus { grid-area: plus; align-self: center; width: 1rem; text-align: center; }
.item-plus::after {
	content: '+'; font-family: var(--display); font-size: 1.3rem; line-height: 1; color: var(--muted);
	transition: color 0.18s ease; display: inline-block;
}
.item-head:hover .item-plus::after { color: var(--fg); }
.item-head[aria-expanded="true"] .item-plus::after { content: '\2212'; color: var(--fg); }

.item-proj .item-title { font-family: var(--display); font-weight: 700; font-size: 1.2rem; letter-spacing: -0.01em; }
.item-paper .item-title { font-style: italic; font-weight: 500; font-size: 1.08rem; }

/* status markers */
.status { display: inline-block; width: 0.6rem; height: 0.6rem; flex-shrink: 0; transform: translateY(-0.04em); }
.status-live { background: var(--fg); }
.status-paused { background: transparent; box-shadow: inset 0 0 0 1.5px var(--fg); }
.status-shelved { background: var(--muted2); }

.item-body { display: grid; grid-template-rows: 0fr; transition: grid-template-rows 0.32s cubic-bezier(0.4,0,0.2,1); }
.item-head[aria-expanded="true"] + .item-body { grid-template-rows: 1fr; }
.item-body-inner { overflow: hidden; min-height: 0; }
.item-body p {
	font-size: 0.95rem; line-height: 1.8; color: var(--fg2); max-width: 48rem;
	padding: 0.1rem 0 1rem;
}
.item-body p.abstract { text-align: justify; hyphens: auto; max-width: 64rem; }

/* link chip */
.chip {
	display: inline-block; margin-bottom: 1rem;
	font-size: 0.78rem; letter-spacing: 0.02em; color: var(--fg);
	text-decoration: none; border-bottom: 1px solid var(--fg); padding-bottom: 1px;
	transition: opacity 0.18s ease;
}
.item-body p + .chip { margin-top: -0.4rem; }
.chip:hover { opacity: 0.55; }

.legend { margin-top: 1.4rem; font-size: 0.8rem; color: var(--muted); display: flex; align-items: center; gap: 0.3rem; flex-wrap: wrap; }
.legend .status { margin-right: 0.1rem; }
.more-note { margin-top: 1.4rem; font-style: italic; font-size: 0.9rem; color: var(--muted2); }
.papers .item-body p.abstract { padding-bottom: 0.7rem; }

/* ── contact ───────────────────────────────────────────────────────── */
.contact-intro { font-size: 1.15rem; line-height: 1.6; color: var(--fg); max-width: 36rem; }
.contact-loc { margin-top: 0.5rem; margin-bottom: 1.6rem; font-size: 0.74rem; letter-spacing: 0.04em; color: var(--muted); }
.contact-list { display: grid; }
.c-link {
	display: grid; grid-template-columns: 6rem 1fr; align-items: baseline; gap: 1rem;
