	color: var(--fg2);
	text-decoration: none;
	transition: color 0.15s ease, border-color 0.15s ease, padding-left 0.25s cubic-bezier(0.4,0,0.2,1);
}
.contact-link:last-child { border-bottom: 1px solid var(--border2); }
.contact-link:hover { color: var(--fg); padding-left: 0.5rem; }
.contact-key {
	font-family: 'JetBrains Mono', monospace;
	font-size: 0.67rem;
	letter-spacing: 0.14em;
	text-transform: uppercase;
	color: var(--muted2);
	transition: color 0.15s ease;
}
.contact-link:hover .contact-key { color: var(--accent); }
.contact-val { font-weight: 500; }

/* ── Site footer ───────────────────────────────────────────────── */
.site-footer {
	position: relative;
	z-index: 2;
	max-width: 72rem;
	margin: 0 auto;
	padding: 2rem 2rem 3rem;
	border-top: 1px solid var(--border2);
