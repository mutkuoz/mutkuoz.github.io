/* ── colophon ──────────────────────────────────────────────────────── */
.colophon { margin-top: 4rem; padding-top: 1.1rem; border-top: 1px solid var(--hair); }
.colophon-line { font-style: italic; font-size: 0.82rem; color: var(--muted); line-height: 1.9; }
.colophon-line.muted { font-style: normal; letter-spacing: 0.02em; }
.ghost-link {
	font-family: var(--serif); font-size: 0.82rem; color: var(--fg);
	background: none; border: none; border-bottom: 1px solid var(--hair); cursor: pointer;
	padding: 0 0 1px; transition: border-color 0.18s ease;
}
.ghost-link:hover { border-color: var(--fg); }

/* ── toast ─────────────────────────────────────────────────────────── */
.toast {
	position: fixed; left: 50%; bottom: 2rem; transform: translateX(-50%) translateY(1.5rem);
	z-index: 450; padding: 0.55rem 1.1rem;
	background: var(--fg); color: var(--bg); font-size: 0.8rem; font-style: italic;
	opacity: 0; pointer-events: none; white-space: nowrap;
	transition: opacity 0.25s ease, transform 0.3s cubic-bezier(0.34,1.4,0.64,1);
}
.toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

/* ── snake minigame ────────────────────────────────────────────────── */
.snake {
	position: fixed; inset: 0; z-index: 400; display: none;
	background: color-mix(in srgb, var(--bg) 93%, transparent);
	backdrop-filter: blur(2px); -webkit-backdrop-filter: blur(2px);
}
.snake.show { display: block; }
#snakeCanvas { position: absolute; inset: 0; width: 100%; height: 100%; display: block; touch-action: none; }
.snake-bar {
	position: absolute; top: 1.2rem; left: 50%; transform: translateX(-50%);
	display: flex; align-items: center; gap: 1.3rem; font-size: 0.82rem; color: var(--muted);
	padding: 0.5rem 1.1rem; background: color-mix(in srgb, var(--bg) 75%, transparent);
	border: 1px solid var(--hair);
}
.snake-title { font-weight: 600; color: var(--fg); letter-spacing: 0.06em; }
.snake-score b { color: var(--fg); }
.snake-keys { color: var(--muted2); }
.snake-close {
	display: flex; align-items: center; justify-content: center; width: 1.5rem; height: 1.5rem;
	margin-left: 0.2rem; padding: 0; border: 1px solid var(--hair); border-radius: 50%;
	background: transparent; color: var(--muted); cursor: pointer; font-size: 0.8rem; line-height: 1;
	transition: color 0.18s ease, border-color 0.18s ease;
}
.snake-close:hover { color: var(--fg); border-color: var(--fg); }
@media (max-width: 480px) { .snake-keys { display: none; } }
.snake-over {
	position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%) scale(0.9);
	text-align: center; display: none; opacity: 0;
	transition: opacity 0.25s ease, transform 0.3s cubic-bezier(0.34,1.4,0.64,1);
}
.snake-over.show { display: block; opacity: 1; transform: translate(-50%,-50%) scale(1); }
.snake-over-t { font-family: var(--display); font-size: 2.2rem; font-weight: 700; color: var(--fg); margin-bottom: 0.4rem; }
.snake-over-s { font-size: 0.9rem; color: var(--muted); margin-bottom: 1.2rem; }
.snake-over-s b { color: var(--fg); }
.snake-btn {
	font-size: 0.82rem; letter-spacing: 0.04em;
	padding: 0.55rem 1.3rem; border: 1.5px solid var(--fg); background: transparent; color: var(--fg);
	cursor: pointer; transition: background 0.18s ease, color 0.18s ease;
}
.snake-btn:hover { background: var(--fg); color: var(--bg); }

/* ── reveal ────────────────────────────────────────────────────────── */
.reveal { opacity: 0; transform: translateY(14px); transition: opacity 0.6s cubic-bezier(0.4,0,0.2,1), transform 0.6s cubic-bezier(0.4,0,0.2,1); }
.reveal.visible { opacity: 1; transform: translateY(0); }

/* ── celestial day/night transition stage ─────────────────────────── */
.sky-canvas {
	position: fixed; inset: 0; z-index: 600; display: none; opacity: 0;
	pointer-events: none; cursor: pointer;
	transition: opacity 0.3s ease;
}
.sky-canvas.show { display: block; opacity: 1; pointer-events: auto; }

/* the toggle winds up before it flings the heavens into motion */
.mode-toggle.casting { animation: toggleCharge 0.5s cubic-bezier(0.34,1.4,0.64,1); }
@keyframes toggleCharge {
	0%   { transform: scale(1) rotate(0); }
	45%  { transform: scale(0.78) rotate(-32deg); }
	100% { transform: scale(1) rotate(0); }
}
/* …and lands with a flourish once the new world is revealed */
.mode-toggle.landed { animation: toggleLand 0.7s cubic-bezier(0.34,1.55,0.5,1); }
@keyframes toggleLand {
	0%   { transform: scale(0.5) rotate(-220deg); }
	60%  { transform: scale(1.18) rotate(12deg); }
	100% { transform: scale(1) rotate(0); }
}

@media (prefers-reduced-motion: reduce) {
	html { scroll-behavior: auto; }
	.reveal { opacity: 1; transform: none; transition: none; }
	.sky-canvas { display: none !important; }
	.mode-toggle.casting, .mode-toggle.landed { animation: none; }
}
